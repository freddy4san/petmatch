generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  fullName               String?
  phoneNumber            String?                 @unique
  bio                    String?
  city                   String?
  password               String
  createdAt              DateTime                @default(now())
  pets                   Pet[]
  sentMessages           Message[]               @relation("SentMessages")
  conversationReadStates ConversationReadState[]
}

model Pet {
  id                    String        @id @default(cuid())
  name                  String
  type                  String
  age                   Int
  breed                 String
  bio                   String?
  gender                PetGender?
  size                  PetSize?
  temperament           String[]      @default([])
  city                  String?
  imageUrl              String?
  imagePublicId         String?
  imageAssetId          String?
  imageVersion          Int?
  imageFormat           String?
  imageResourceType     String?
  imageBytes            Int?
  imageWidth            Int?
  imageHeight           Int?
  imageOriginalFilename String?
  imageUploadedAt       DateTime?
  ownerId               String
  owner                 User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sentInteractions      Interaction[] @relation("SentInteractions")
  receivedInteractions  Interaction[] @relation("ReceivedInteractions")
  matchesAsPet1         Match[]       @relation("MatchPet1")
  matchesAsPet2         Match[]       @relation("MatchPet2")

  @@index([ownerId])
  @@index([city])
}

enum PetGender {
  MALE
  FEMALE
  UNKNOWN
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum InteractionType {
  LIKE
  PASS
}

model Interaction {
  id        String          @id @default(cuid())
  fromPetId String
  toPetId   String
  type      InteractionType
  createdAt DateTime        @default(now())
  fromPet   Pet             @relation("SentInteractions", fields: [fromPetId], references: [id], onDelete: Cascade)
  toPet     Pet             @relation("ReceivedInteractions", fields: [toPetId], references: [id], onDelete: Cascade)

  @@unique([fromPetId, toPetId])
  @@index([fromPetId])
  @@index([toPetId])
  @@index([fromPetId, type])
  @@map("interactions")
}

model Match {
  id           String        @id @default(cuid())
  pet1Id       String
  pet2Id       String
  createdAt    DateTime      @default(now())
  pet1         Pet           @relation("MatchPet1", fields: [pet1Id], references: [id], onDelete: Cascade)
  pet2         Pet           @relation("MatchPet2", fields: [pet2Id], references: [id], onDelete: Cascade)
  conversation Conversation?

  @@unique([pet1Id, pet2Id])
  @@index([pet1Id])
  @@index([pet2Id])
  @@map("matches")
}

model Conversation {
  id         String                  @id @default(cuid())
  matchId    String                  @unique
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  match      Match                   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages   Message[]
  readStates ConversationReadState[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, senderUserId, createdAt])
  @@index([senderUserId])
  @@map("messages")
}

model ConversationReadState {
  id                String       @id @default(cuid())
  conversationId    String
  userId            String
  lastReadAt        DateTime?
  lastReadMessageId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, userId])
  @@map("conversation_read_states")
}
